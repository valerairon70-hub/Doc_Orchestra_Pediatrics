# Скопируй этот файл в .env и заполни значения
# НИКОГДА не коммить .env в git!

# --------------------------------------------------------------------------
# MVP (mvp.py) — обязательно
# --------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...your_key_here

# Имя врача — используется в приветствии ассистента
# Например: "доктора Иванова", "Ивана Сергеевича", "врача"
DOCTOR_NAME=врача

# Пароль для входа в кокпит врача (по умолчанию: doctor123)
# Смени на что-то надёжное перед показом врачу!
COCKPIT_PASSWORD=doctor123

# Telegram-уведомления врачу (необязательно, но рекомендуется)
# Как получить: создай бота через @BotFather → скопируй токен
# DOCTOR_CHAT_ID: открой @userinfobot в Telegram → скопируй свой ID
# TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DOCTOR_CHAT_ID=123456789

# --------------------------------------------------------------------------
# Полная версия (doc_orchestra.py) — нужен Gemini API ключ
# --------------------------------------------------------------------------
# GEMINI_API_KEY=your_gemini_api_key_here

# --- Модели (опционально, можно переопределить) ---
# MODEL_DIALOGUE=gemini-2.5-flash
# MODEL_VISION=gemini-2.5-flash
# MODEL_MX=gemini-2.5-pro
# MODEL_LONGITUDINAL=gemini-2.5-flash

# --- База данных ---
# DATABASE_URL=sqlite+aiosqlite:///data/patients.db

# --- Клинические пороги для Red Flag алертов (показаны значения по умолчанию) ---
# RED_FLAG_HB_GDL=7.0
# RED_FLAG_HB_DROP_GDL=2.0
# RED_FLAG_FERRITIN_UGL=10.0
