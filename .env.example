# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Required ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional overrides ---
# MODEL_DIALOGUE=gemini-2.5-flash
# MODEL_VISION=gemini-2.5-flash
# MODEL_MX=gemini-2.5-pro
# MODEL_LONGITUDINAL=gemini-2.5-flash

# DATABASE_URL=sqlite+aiosqlite:///data/patients.db

# COCKPIT_MODE=cli   # or "web" for Phase 2
# WEB_PORT=8080

# --- Clinical thresholds (defaults shown) ---
# RED_FLAG_HB_GDL=7.0
# RED_FLAG_HB_DROP_GDL=2.0
# RED_FLAG_FERRITIN_UGL=10.0
